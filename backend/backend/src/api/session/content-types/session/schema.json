{
    "kind": "collectionType",
    "collectionName": "sessions",
    "info": {
        "singularName": "session",
        "pluralName": "sessions",
        "displayName": "Session"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "date": {
            "type": "date",
            "required": true
        },
        "time": {
            "type": "string"
        },
        "maxCapacity": {
            "type": "integer",
            "default": 100,
            "min": 1
        },
        "location": {
            "type": "string"
        },
        "course": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::course.course"
        },
        "duration": {
            "type": "integer"
        },
        "sessionType": {
            "type": "enumeration",
            "enum": [
                "live_webinar",
                "workshop"
            ],
            "default": "live_webinar"
        },
        "meetingUrl": {
            "type": "string"
        },
        "students": {
            "type": "relation",
            "relation": "manyToMany",
            "target": "plugin::users-permissions.user"
        },
        "attendance": {
            "type": "json"
        },
        "trainer": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "plugin::users-permissions.user"
        }
    }
}