{
  "kind": "collectionType",
  "collectionName": "user_subscriptions",
  "info": {
    "singularName": "user-subscription",
    "pluralName": "user-subscriptions",
    "displayName": "User Subscription",
    "description": "Tracks active subscriptions for each user"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "plan": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::subscription-plan.subscription-plan"
    },
    "start_date": {
      "type": "date",
      "required": true
    },
    "end_date": {
      "type": "date",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "active",
        "expired",
        "cancelled"
      ],
      "default": "pending"
    },
    "billing_cycle": {
      "type": "enumeration",
      "enum": [
        "monthly",
        "quarterly",
        "semiannually",
        "yearly"
      ],
      "default": "monthly"
    },
    "remaining_credits": {
      "type": "integer",
      "default": 0
    },
    "payment_reference": {
      "type": "string"
    },
    "payment_method": {
      "type": "enumeration",
      "enum": [
        "cash",
        "card"
      ],
      "default": "cash"
    },
    "payment_deadline": {
      "type": "datetime"
    },
    "rejection_reason": {
      "type": "string"
    },
    "low_credits_alert_sent": {
      "type": "boolean",
      "default": false
    },
    "expiration_alert_sent": {
      "type": "boolean",
      "default": false
    },
    "original_price": {
      "type": "decimal"
    },
    "discount_amount": {
      "type": "decimal",
      "default": 0
    },
    "final_price": {
      "type": "decimal"
    }
  }
}